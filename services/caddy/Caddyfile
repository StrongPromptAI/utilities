{
    admin off
    auto_https off           # Railway terminates TLS at the edge
    default_bind 0.0.0.0     # IPv4 healthcheck compatibility
}

# ── Shared snippets ──────────────────────────────────────────────────────────

(security_headers) {
    header {
        X-Content-Type-Options    "nosniff"
        X-Frame-Options           "SAMEORIGIN"
        Referrer-Policy           "strict-origin-when-cross-origin"
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        -Server
    }
}

(common) {
    import security_headers
    encode gzip
}

# ── OpenWebUI — oxp.chat.strongprompt.ai ─────────────────────────────────────
# SSE streaming requires flush_interval -1 so chat tokens arrive incrementally
# instead of in buffered bursts.

http://oxp.chat.strongprompt.ai:{$PORT:8080} {
    import common
    reverse_proxy openwebui.railway.internal:8080 {
        # Railway terminates TLS at its edge, then forwards HTTP to Caddy.
        # Force X-Forwarded-Proto=https so OpenWebUI generates https:// URLs
        # in OIDC redirect_uri, session cookies, etc. Without this, the OIDC
        # flow breaks with a scheme mismatch at the IdP.
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host oxp.chat.strongprompt.ai
        flush_interval -1
    }
}

# ── oxp.files (FastAPI app) — oxp.files.strongprompt.ai ──────────────────────
# Replaced SFTPGo on 2026-05-06 (see plans/26-5-5_oxp-files-fastapi-rewrite.md).
# File bodies bypass Caddy entirely via presigned URLs to Tigris, so the proxy
# only carries small auth-flow / API requests; default timeouts are fine.

http://oxp.files.strongprompt.ai:{$PORT:8080} {
    import common

    reverse_proxy oxp-files-app.railway.internal:8080 {
        header_up X-Forwarded-Proto https
        header_up X-Forwarded-Host oxp.files.strongprompt.ai
    }
}

# ── Catch-all — healthcheck + direct-URL safety net ──────────────────────────
# Railway's healthcheck and anyone hitting the caddy-*.up.railway.app URL
# directly land here. Route to OpenWebUI as a sensible default.

:{$PORT:8080} {
    handle /health {
        respond "OK" 200
    }

    import common
    reverse_proxy openwebui.railway.internal:8080 {
        flush_interval -1
    }
}
